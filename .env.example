# -----------------------------------------------------------------------------
# seiran - 環境変数設定テンプレート (.env.example)
# このファイルを .env にコピーして編集してください。
# -----------------------------------------------------------------------------

# 1. サーバー起動ポート
PORT=3000

# 2. データベース接続情報 (PostgreSQL)
# 開発用 Docker Compose のデフォルト値: postgres://postgres:postgrespassword@localhost:5432/seiran
DATABASE_URL=postgres://postgres:postgrespassword@localhost:5432/seiran

# 3. 認証プロバイダの選択 (auth0 または local)
AUTH_PROVIDER=local

# 4. Auth0 連携時の設定 (AUTH_PROVIDER=auth0 の場合に必要)
# Auth0 の API 登録で設定する Identifier (Audience)
AUTH0_AUDIENCE=https://seiran.org/api
# Auth0 のテナントドメイン (末尾の '/' が必須です)
AUTH0_ISSUER=https://YOUR_TENANT_DOMAIN.us.auth0.com/

# 5. シークレット設定ディレクトリ
# JWT_SECRET と AT Protocol 鍵ペアは config/secrets.toml に自動生成されます。
# ユーザーが手動で設定する必要はありません。
# このディレクトリをまるごと Docker ボリュームにマウントして永続化してください。
SEIRAN_CONFIG_DIR=./config
