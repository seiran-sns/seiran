# =============================================================================
# seiran 環境変数設定テンプレート
# このファイルを .env にコピーして編集してください。
# =============================================================================

# ─── ドメイン ────────────────────────────────────────────────────────────────
LOCAL_DOMAIN=beta.seiran.org
ATP_PDS_ORIGIN=https://beta.seiran.org

# ─── 起動ポート ──────────────────────────────────────────────────────────────
PORT=3000
FEDERATION_INBOX_PORT=3001

# ─── データベース ─────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=seiran

# ローカル開発（cargo run）時はこちらを使用。
# Docker 起動時は docker-compose.yml が DATABASE_URL を db:5432 に上書きします。
DATABASE_URL=postgres://postgres:postgrespassword@localhost:5432/seiran

# ─── ジョブキュー（split-role構成のみ）───────────────────────────────────────
# `--role all`（モノリスモード）では常にオンメモリキューを使うため不要。
# api / federation / worker を別プロセス・別コンテナで動かす split-role 構成
# （docker-compose.yml の大規模構成）でのみ、プロセス間でキューを共有するために
# 必要になる。docker-compose.yml では自動的に redis サービスを指す値に上書きされる。
# 未設定のまま split-role 起動すると、各プロセスが孤立したオンメモリキューになり
# enqueue したジョブが別プロセスの Worker に届かない（起動ログに警告が出る）。
# REDIS_URL=redis://localhost:6379

# ─── シークレット自動生成ディレクトリ ────────────────────────────────────────
# JWT_SECRET と AP/ATP 鍵ペアは config/secrets.toml に自動生成されます。
# Docker では config-data ボリュームにマウントされます。
SEIRAN_CONFIG_DIR=./config

# ─── Cloudflare Tunnel ───────────────────────────────────────────────────────
# Zero Trust ダッシュボード (https://one.dash.cloudflare.com) でトークンを取得してください。
# Tunnel の Ingress Route: beta.seiran.org → http://nginx:80
TUNNEL_TOKEN=your-tunnel-token-here

# ─── Cloudflare DNS API（ハンドル検証 TXT レコード） ──────────────────────────
# AT Protocol ハンドル検証のために _atproto.{handle} TXT レコードを自動作成します。
# 未設定時は HTTP /.well-known/atproto-did のみを使用します。
#
# API トークンの作成: Cloudflare ダッシュボード → My Profile → API Tokens
#   必要な権限: Zone > DNS > Edit（対象ゾーンのみ）
# Zone ID: ドメインのダッシュボード右サイドバーに表示
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
CLOUDFLARE_ZONE_ID=your-zone-id-here

# ─── SMTP（メール送信）※ DEPRECATED ────────────────────────────────────────
# SMTP 設定は DB の site_settings テーブルで管理するようになりました。
# 管理者 API（PATCH /api/admin/site-settings）で設定してください。
# 以下の環境変数は使用されません。
#
# # DEPRECATED: SMTP_HOST=smtp.resend.com
# # DEPRECATED: SMTP_PORT=587
# # DEPRECATED: SMTP_USERNAME=resend
# # DEPRECATED: SMTP_PASSWORD=your-resend-api-key-here
# # DEPRECATED: SMTP_FROM=info@yourdomain.com
# # DEPRECATED: SMTP_TLS=starttls
